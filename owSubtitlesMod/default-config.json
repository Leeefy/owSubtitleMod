{
  "$schema": "https://raw.githubusercontent.com/ow-mods/owml/master/schemas/config_schema.json",
  "enabled": true,
   "settings": {

      "seperator1": {
         "type": "separator"
      },

      "X-pos": {
         "type": "slider",
         "min": 0,
         "max": 2000,
         "value": 75,
         "tooltip": "The position of the subtitles horizontally"
      },

      "Y-pos": {
         "type": "slider",
         "min": 0,
         "max": 2000,
         "value": 75,
         "tooltip": "The position of the subtitles vertically"
      },

      "seperator2": {
         "type": "separator"
      },

      "Font size": {
         "type": "slider",
         "min": 0,
         "max": 100,
         "value": 25,
         "tooltip": "The size of the subtitles font"
      },

      "Sensitivity": {
         "type": "slider",
         "min": 0,
         "max": 100,
         "value": 50,
         "tooltip": "The sensitivity of the subtitles"
      },

      "Distance": {
         "type": "slider",
         "min": 1,
         "max": 100,
         "value": 50,
         "tooltip": "The distance that the subtitles will pick up noise"
      }
   }
}
